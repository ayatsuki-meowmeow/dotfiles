# macOS
.DS_Store

# Editors and IDEs
*.swp
*.swo

# Other common files
*.log
*.tmp

# for security reasons
.ssh/*
!.ssh/config
!.ssh/config.local.template
.gitconfig.local
.zshrc.local
.config/gh/*

# FVM Version Cache
*.fvm

# Raycast extensions (再インストール可能な生成物。自動更新で大量 diff が出るため追跡しない)
.config/raycast/extensions/

# Claude Code (機密・揮発性が高いものは追跡しない)
.claude/.credentials.json
.claude/auth.json
.claude/sessions/
.claude/projects/
.claude/*.log
